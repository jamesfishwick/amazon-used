{
  "manifest_version": 3,
  "name": "Cheapest Read",
  "version": "1.4.1",
  "description": "Find the lowest total price (item + shipping) across new and used book offers on your wishlist.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://www.amazon.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/hz/wishlist/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.com/dp/*/ref=olp-opf-redir*",
        "https://www.amazon.com/gp/offer-listing/*"
      ],
      "js": ["offers-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}